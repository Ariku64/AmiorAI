# AmiorAI — repository exclusions

# Python caches and test artefacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage/
reports/
test-results/

# Local Python environments and embedded runtimes
/.venv/
/venv/
/env/
/ENV/
/python_embed/
/tts_server/python_chatterbox/
/tts_server/python_qwen/
/tts_server/venv/
/tts_server/venv_chatterbox/
/tts_server/venv_qwen/

# Downloaded AI models and caches
/models/
/tts_server/models/
/.cache/
/huggingface/
huggingface_cache/
*.safetensors
*.ckpt
*.pt
*.pth
*.onnx
*.gguf

# Personal and generated AmiorAI data
/data/
/generated/
/outputs/
/output/
/uploads/
/backups/
/logs/
*.db
*.db-journal
*.sqlite
*.sqlite3
*.log

# Local secrets and machine-specific configuration
.env
.env.*
!.env.example
/secrets/
secrets.json
credentials.json
token.json
*.pem
*.key
*.pfx
.legal_acceptance_*

# Temporary files
/tmp/
/temp/
*.tmp
*.temp
*.bak
*.old
*.swp
*~

# Build and release artefacts
/build/
/dist/
/release/
/releases/
*.spec
*.exe
*.msi
*.zip
*.7z
*.rar
*.sha256
*.sha256.txt

# IDE and editor files
.vscode/
.idea/
.vs/
*.code-workspace

# Node tooling if used locally
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Operating-system files
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride
.directory
